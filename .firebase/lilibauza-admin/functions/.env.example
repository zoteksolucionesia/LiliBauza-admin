# Variables de entorno requeridas para LiliBauza-admin
# Copia este archivo como .env.local y rellena los valores reales.

# Supabase - Consola: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anonima-aqui

# Referencia del proyecto (la parte entre tu-proyecto en la URL de Supabase).
# Usada por el middleware para detectar la cookie de sesión.
NEXT_PUBLIC_SUPABASE_PROJECT_REF=tu-proyecto
